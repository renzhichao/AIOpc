# OpenClaw Remote Agent - Local Development Environment Variables

# Platform Configuration
PLATFORM_URL=http://118.25.0.190:3000
AGENT_PORT=3000
OPENCLAW_SERVICE_URL=http://openclaw-service:3001

# Docker-specific paths (for local docker-compose)
CREDENTIALS_PATH=/app/credentials/credentials.json
LOG_PATH=/app/logs/agent.log

# Node Environment
NODE_ENV=production

# DeepSeek API Configuration (for OpenClaw Service)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_MODEL=deepseek-chat

# Ngrok Configuration (for exposing local agent to internet)
# Get your free authtoken from https://ngrok.com/signup
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
# Optional: Custom domain (requires paid ngrok account)
# NGROK_DOMAIN=your-custom-domain.ngrok.io
