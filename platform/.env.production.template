# AIOpc Platform - 生产环境配置模板
# 复制此文件为 .env.production 并填写真实值

################################################################################
# 服务器配置
################################################################################
BACKEND_PORT=3000
FRONTEND_PORT=5173
NODE_ENV=production

################################################################################
# 数据库配置
################################################################################
DB_HOST=postgres
DB_PORT=5432
DB_NAME=opclaw
DB_USER=opclaw
DB_PASSWORD=your_secure_password_here

# 生成强密码命令: openssl rand -base64 32
# 请将生成的密码替换到下面的位置

################################################################################
# Redis 配置
################################################################################
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# 生成强密码命令: openssl rand -base64 32
# 请将生成的密码替换到下面的位置

################################################################################
# JWT 配置
################################################################################
JWT_SECRET=your_jwt_secret_here

# 生成 JWT Secret: openssl rand -base64 64
# 用于签名和验证 JWT Token

JWT_EXPIRES_IN=7d

################################################################################
# 飞书配置
################################################################################
# 在飞书开放平台创建应用后获取
# https://open.feishu.cn/app

FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxx

# OAuth 回调地址 (根据实际部署域名修改)
FEISHU_REDIRECT_URI=https://your-domain.com/oauth/callback

# 加密密钥 (用于二维码签名验证)
FEISHU_ENCRYPT_KEY=your_encrypt_key_here
# 生成: openssl rand -base64 32

# 验证令牌 (事件回调验证)
FEISHU_VERIFICATION_TOKEN=your_verify_token_here
# 生成: openssl rand -hex 16

################################################################################
# DeepSeek API 配置
################################################################################
# 在 DeepSeek 平台获取 API Key
# https://platform.deepseek.com/api_keys

DEEPSEEK_API_KEY=your_deepseek_api_key_here

################################################################################
# Nginx 配置 (如果使用 Nginx)
################################################################################
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

################################################################################
# 日志配置
################################################################################
LOG_LEVEL=info
# 可选值: error, warn, info, debug

################################################################################
# Docker 配置
################################################################################
DOCKER_SOCKET_PATH=/var/run/docker.sock

################################################################################
# 实例配置 (可选)
################################################################################
# 实例容器网络
INSTANCE_NETWORK=opclaw-instances

# 实例容器资源限制
INSTANCE_CPU_LIMIT=2.0
INSTANCE_MEMORY_LIMIT=2g

################################################################################
# 监控配置 (可选)
################################################################################
# Prometheus 端点 (如果使用)
METRICS_ENABLED=true
METRICS_PORT=9090
