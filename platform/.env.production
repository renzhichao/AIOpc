################################################################################
# DeepSeek API 配置
################################################################################
# 方案 A: 部署后通过配置页面修改
# 可以替换为其他兼容 OpenAI API 格式的 LLM 提供商：
# - 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# - 智谱 GLM: https://open.bigmodel.cn/api/paas/v4
# - 文心一言: https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
# - 月之暗面: https://api.moonshot.cn/v1

DEEPSEEK_API_KEY=sk-CONFIGURE_IN_PLATFORM_ADMIN_PANEL
# 或者使用环境变量指定其他 LLM 提供商的 API Key

################################################################################
# Nginx 配置（如果使用）
################################################################################
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

################################################################################
# 日志配置
################################################################################
LOG_LEVEL=info

################################################################################
# Docker 配置
################################################################################
DOCKER_SOCKET_PATH=/var/run/docker.sock

################################################################################
# 实例配置（可选）
################################################################################
INSTANCE_NETWORK=opclaw-instances
INSTANCE_CPU_LIMIT=2.0
INSTANCE_MEMORY_LIMIT=2g

# Feishu OAuth URLs
FEISHU_OAUTH_AUTHORIZE_URL=https://open.feishu.cn/open-apis/authen/v1/authorize
FEISHU_OAUTH_TOKEN_URL=https://open.feishu.cn/open-apis/authen/v3/oidc/access_token
FEISHU_USER_INFO_URL=https://open.feishu.cn/open-apis/authen/v1/user_info

################################################################################
# 钉钉配置
################################################################################
# 钉钉应用信息
DINGTALK_APP_ID=dingxyzxyz
DINGTALK_APP_SECRET=CONFIGURE_YOUR_DINGTALK_APP_SECRET
DINGTALK_REDIRECT_URI=http://localhost:3000/oauth/callback

# 钉钉 OAuth URLs
DINGTALK_OAUTH_AUTHORIZE_URL=https://login.dingtalk.com/oauth2/auth
DINGTALK_OAUTH_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/userAccessToken
DINGTALK_USER_INFO_URL=https://api.dingtalk.com/v1.0/contact/users/me

# 多平台 OAuth 配置
OAUTH_DEFAULT_PLATFORM=feishu
OAUTH_ENABLED_PLATFORMS=feishu,dingtalk

# OAuth 配置选项
# 生产环境默认要求HTTPS redirect_uri，设为true可允许HTTP（仅用于测试）
OAUTH_ALLOW_HTTP=true

# OAuth 允许的域名白名单（逗号分隔）
OAUTH_ALLOWED_DOMAINS=localhost,127.0.0.1,113.105.103.165,renava.cn,118.25.0.190
