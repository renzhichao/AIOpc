# Production Environment Configuration
# Copy this file to .env.production and fill in the actual values
# IMPORTANT: Never commit .env.production with real credentials to version control

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ============================================
# Database Configuration
# ============================================
# Connection settings
DB_HOST=your-production-db-host.example.com
DB_PORT=5432
DB_NAME=opclaw_production
DB_USERNAME=opclaw
DB_PASSWORD=your-strong-database-password-here

# Schema synchronization (NEVER enable in production)
DB_SYNC=false

# Connection pooling (optimized for production)
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=5
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000

# Logging (minimal in production)
DB_LOG_LEVEL=error

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=your-production-redis-host.example.com
REDIS_PORT=6379
REDIS_PASSWORD=your-strong-redis-password-here
REDIS_DB=0

# Connection pooling
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_RETRY_STRATEGY_DELAY=2000
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=3000

# ============================================
# Docker Configuration
# ============================================
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_NETWORK=opclaw-network

# Container resource limits
DOCKER_CONTAINER_CPU_LIMIT=2.0
DOCKER_CONTAINER_MEMORY_LIMIT=2g
DOCKER_CONTAINER_MEMORY_SWAP_LIMIT=2g

# ============================================
# Feishu OAuth Configuration
# ============================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxx
FEISHU_REDIRECT_URI=https://your-domain.com/oauth/callback
FEISHU_OAUTH_AUTHORIZE_URL=https://open.feishu.cn/open-apis/authen/v1/authorize
FEISHU_OAUTH_TOKEN_URL=https://open.feishu.cn/open-apis/authen/v3/oidc/access_token
FEISHU_USER_INFO_URL=https://open.feishu.cn/open-apis/authen/v1/user_info

# Security (for webhook validation)
FEISHU_VERIFY_TOKEN=your-verify-token-min-32-chars
FEISHU_ENCRYPT_KEY=your-encrypt-key

# ============================================
# DeepSeek LLM Configuration
# ============================================
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4000
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_TIMEOUT=30000

# API Key pool management
DEEPSEEK_API_KEY_POOL_ENABLED=true
DEEPSEEK_MIN_POOL_SIZE=5
DEEPSEEK_MAX_POOL_SIZE=20

# ============================================
# Security Configuration
# ============================================
# JWT settings
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# Session management
SESSION_SECRET=your-session-secret-key-minimum-32-characters
SESSION_MAX_AGE=604800000

# Encryption (for sensitive data)
ENCRYPTION_KEY=your-encryption-key-min-32-characters
ENCRYPTION_ALGORITHM=aes-256-gcm

# CORS (restrict to your domain)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ============================================
# Monitoring Configuration
# ============================================
# Metrics collection
ENABLE_METRICS=true
METRICS_COLLECTION_INTERVAL=30000
METRICS_RETENTION_DAYS=30

# Health check intervals
HEALTH_CHECK_INTERVAL=60000
HEALTH_CHECK_TIMEOUT=10000
HEALTH_CHECK_FAILURE_THRESHOLD=3

# Performance monitoring
PERFORMANCE_MONITORING_ENABLED=true
SLOW_QUERY_THRESHOLD=1000
SLOW_API_THRESHOLD=5000

# ============================================
# Logging Configuration
# ============================================
# Log levels: error, warn, info, http, debug
LOG_LEVEL=info

# Log file settings
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_ERROR_MAX_FILES=30d

# Request logging
LOG_REQUEST_ENABLED=true
LOG_REQUEST_BODY=false
LOG_RESPONSE_BODY=false

# ============================================
# SSL/TLS Configuration
# ============================================
# Trust proxy (when using reverse proxy like Nginx)
TRUST_PROXY=true

# Force HTTPS (uncomment in production with SSL)
# FORCE_HTTPS=true

# ============================================
# Backup Configuration
# ============================================
# Database backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/var/backups/opclaw

# ============================================
# Instance Management Configuration
# ============================================
# Instance lifecycle
INSTANCE_MAX_COUNT_PER_USER=5
INSTANCE_DEFAULT_TTL=86400000
INSTANCE_GRACE_PERIOD=3600000

# Resource limits
INSTANCE_MAX_MEMORY=2g
INSTANCE_MAX_CPU=2.0
INSTANCE_MAX_DISK=10g

# Renewal settings
INSTANCE_RENEWAL_ENABLED=true
INSTANCE_RENEWAL_MAX_EXTENSIONS=10
INSTANCE_RENEWAL_WINDOW_DAYS=7

# ============================================
# API Rate Limiting (per endpoint)
# ============================================
# Instance management
INSTANCE_CREATE_RATE_LIMIT=5
INSTANCE_START_RATE_LIMIT=10
INSTANCE_STOP_RATE_LIMIT=20

# API key operations
APIKEY_CREATE_RATE_LIMIT=3
APIKEY_DELETE_RATE_LIMIT=10

# ============================================
# Feature Flags
# ============================================
FEATURE_QR_CODE_ENABLED=true
FEATURE_AUTO_RENEWAL_ENABLED=true
FEATURE_METRICS_ENABLED=true
FEATURE_WEBHOOK_ENABLED=true

# ============================================
# Development/Testing (DISABLE IN PRODUCTION)
# ============================================
# Mock OAuth (MUST be false in production)
MOCK_OAUTH_ENABLED=false

# Debug mode (MUST be false in production)
DEBUG_MODE=false

# ============================================
# Additional Notes
# ============================================
#
# 1. Security Checklist:
#    - All passwords must be strong (min 16 chars, mixed case, numbers, symbols)
#    - All secrets must be at least 32 characters
#    - Use different passwords for different services
#    - Enable SSL/TLS for all external connections
#    - Restrict CORS to your actual domain
#    - Set TRUST_PROXY=true when using reverse proxy
#
# 2. Performance Optimization:
#    - Adjust DB_MAX_CONNECTIONS based on your load
#    - Configure Redis clustering for high availability
#    - Enable CDN for static assets
#    - Use connection pooling everywhere
#
# 3. Monitoring:
#    - Set up external monitoring (Prometheus, Grafana, DataDog)
#    - Configure alerting for critical metrics
#    - Review logs regularly
#    - Set up log aggregation (ELK, Splunk)
#
# 4. Backup Strategy:
#    - Automated daily backups
#    - Store backups in separate location
#    - Test restore procedure regularly
#    - Document recovery process
