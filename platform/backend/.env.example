# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=opclaw
DB_USERNAME=opclaw
DB_PASSWORD=your_password

# Database Sync (WARNING: Only use in development!)
# Set to 'true' to auto-sync schema (NOT for production)
# Set to 'false' to use migrations (recommended for production)
DB_SYNC=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT Configuration
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Feishu Configuration
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxx
FEISHU_REDIRECT_URI=http://localhost:3000/oauth/callback
FEISHU_OAUTH_AUTHORIZE_URL=https://open.feishu.cn/open-apis/authen/v1/authorize
FEISHU_OAUTH_TOKEN_URL=https://open.feishu.cn/open-apis/authen/v1/oidc/access_token
FEISHU_USER_INFO_URL=https://open.feishu.cn/open-apis/authen/v1/user_info
FEISHU_VERIFY_TOKEN=your_verify_token
FEISHU_ENCRYPT_KEY=your_encrypt_key

# OAuth Security Configuration (TASK-004)
# Allowed redirect URI domains for OAuth callbacks
# Format: comma-separated list of domains
# Supports wildcards for subdomains: *.example.com
# Examples:
#   - Single domain: example.com
#   - Multiple domains: example.com,localhost,127.0.0.1
#   - With wildcards: *.example.com,*.test.com
# Default (if not set): localhost,127.0.0.1 (development only)
OAUTH_ALLOWED_DOMAINS=example.com,localhost,127.0.0.1

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key

# Docker Configuration
DOCKER_SOCKET_PATH=/var/run/docker.sock

# WebSocket Configuration (TASK-006)
WS_ENABLED=true
WS_PORT=3001
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=50
WS_MESSAGE_TIMEOUT=30000

# Instance Registry Configuration (TASK-007)
REGISTRY_HEALTH_CHECK_ENABLED=true
REGISTRY_HEALTH_CHECK_INTERVAL=15000
REGISTRY_HEARTBEAT_TIMEOUT=30000

# Message Router Configuration (TASK-008)
MESSAGE_RETRY_INTERVAL=30000
MESSAGE_MAX_RETRIES=3
MESSAGE_QUEUE_TIMEOUT=60000
LOCAL_INSTANCE_TIMEOUT=10000
