{
  "name": "aiopcn-backend",
  "version": "1.0.0",
  "description": "AIOpc Platform Backend - Scan-to-Enable OpenClaw Cloud Service",
  "main": "dist/app.js",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e --detectOpenHandles --forceExit",
    "test:e2e:debug": "jest --testPathPattern=tests/e2e --detectOpenHandles --forceExit --verbose",
    "test:e2e:coverage": "jest --testPathPattern=tests/e2e --coverage --detectOpenHandles --forceExit",
    "test:e2e:report": "jest --testPathPattern=tests/e2e --detectOpenHandles --forceExit --reporters=default --reporters=jest-junit",
    "build": "tsc",
    "dev": "nodemon",
    "dev:docker": "docker-compose -f docker/docker-compose.dev.yml up -d && pnpm run dev",
    "docker:up": "docker-compose -f docker/docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker/docker-compose.dev.yml logs -f",
    "start": "node dist/app.js",
    "db:migrate": "typeorm migration:run -d typeorm.config.ts",
    "db:revert": "typeorm migration:revert -d typeorm.config.ts",
    "db:generate": "typeorm migration:generate -d typeorm.config.ts migrations/",
    "db:create": "typeorm migration:create -d typeorm.config.ts migrations/",
    "db:seed": "ts-node src/scripts/seedApiKeys.ts",
    "db:init": "ts-node scripts/init-database.ts",
    "typeorm": "typeorm"
  },
  "keywords": [
    "opclaw",
    "ai",
    "agent",
    "platform"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.7.4",
    "config": "^4.4.1",
    "cors": "^2.8.5",
    "dockerode": "^4.0.9",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.3",
    "tsoa": "7.0.0-alpha.0",
    "typedi": "^0.10.0",
    "typeorm": "^0.3.28",
    "typeorm-typedi-extensions": "^0.4.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "8.3.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
