# AIOpc 生产环境变量配置
#
# 重要提示：
# - 此文件包含敏感信息，请勿提交到版本控制系统
# - 所有密码和密钥都应使用强随机字符串
# - 生产环境部署前必须修改所有默认值

# ============================================
# 应用配置
# ============================================
NODE_ENV=production
LOG_LEVEL=info

# ============================================
# 数据库配置
# ============================================
POSTGRES_DB=opclaw
POSTGRES_USER=opclaw
# 请修改为强密码（至少16个字符，包含大小写字母、数字和符号）
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_NOW

# ============================================
# Redis配置
# ============================================
# 请修改为强密码（至少16个字符）
REDIS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_NOW

# ============================================
# Feishu OAuth 配置
# ============================================
# 从 https://open.feishu.cn/app 获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxx
FEISHU_REDIRECT_URI=https://renava.cn/oauth/callback

# ============================================
# DeepSeek API 配置
# ============================================
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ============================================
# 安全配置
# ============================================
# JWT密钥（至少32个字符）
JWT_SECRET=CHANGE_THIS_TO_RANDOM_32_CHAR_STRING_HERE
JWT_EXPIRES_IN=7d

# CORS允许的来源
CORS_ALLOWED_ORIGINS=https://renava.cn,https://www.renava.cn

# ============================================
# Docker配置
# ============================================
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_NETWORK=opclaw-network

# ============================================
# 构建配置
# ============================================
BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
